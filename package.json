{
  "name": "trace-cue",
  "version": "0.0.0",
  "private": true,
  "description": "Local-first visual evidence and review CLI for humans and AI agents.",
  "type": "module",
  "bin": {
    "trace-cue": "./bin/trace-cue.js",
    "trace-cue-mcp": "./bin/trace-cue-mcp.js",
    "browser-debug": "./bin/browser-debug.js",
    "browser-debug-mcp": "./bin/browser-debug-mcp.js"
  },
  "exports": {
    ".": "./src/api.js",
    "./schemas/*": "./schemas/*.schema.json"
  },
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "ahr:responses-adapter": "node ./bin/trace-cue-ahr-responses-adapter.js",
    "control-center:build": "vite build --config control-center/vite.config.mjs",
    "control-center:dev": "vite --config control-center/vite.config.mjs --host 127.0.0.1",
    "development-workflow:check": "node ./tools/check_development_workflow.mjs",
    "development-workflow:contract-check": "node --test tests/development-workflow.test.js",
    "document-sync:check": "node ./tools/check_document_sync.mjs --worktree",
    "document-sync:contract-check": "node --test tests/document-sync.test.js",
    "doctor": "node ./bin/trace-cue.js doctor --json",
    "test": "node --test tests/architecture.test.js tests/cli.test.js tests/control-center.test.js tests/control-center-agentic-review.test.js tests/dashboard-settings-store.test.js tests/development-workflow.test.js tests/document-sync.test.js tests/playwright-test.test.js",
    "test:browser": "npm run control-center:build && TRACE_CUE_BROWSER_SMOKE=1 node --test tests/browser-smoke.test.js",
    "test:rename-readiness": "node ./tools/check_rename_readiness.mjs",
    "test:pack": "node ./tools/pack-dry-run.mjs",
    "test:pack-install": "node ./tools/pack-install-smoke.mjs",
    "release:check": "npm test && npm run control-center:build && npm run test:rename-readiness && npm run test:pack && npm run test:pack-install"
  },
  "files": [
    ".codex-plugin/",
    ".mcp.json",
    "bin/",
    "control-center/",
    "src/",
    "schemas/",
    "templates/",
    "ops/OPERATION_POLICY.json",
    "ops/ARTIFACT_ROOT_POLICY.json",
    "skills/trace-cue-review/SKILL.md",
    "README.md",
    "CHANGELOG.md",
    "docs/design-system/",
    "docs/workflow/CONSUMER_USAGE.md",
    "docs/workflow/IDENTITY_MIGRATION.md",
    "docs/workflow/SECURITY.md",
    "docs/workflow/RELEASE.md",
    "docs/workflow/VERIFICATION.md",
    "skills/browser-debug-review/SKILL.md"
  ],
  "keywords": [
    "visual-review",
    "playwright",
    "cli",
    "ui-testing",
    "agent-tools",
    "mcp"
  ],
  "license": "UNLICENSED",
  "dependencies": {
    "playwright": "^1.61.0"
  },
  "devDependencies": {
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "vite": "^8.1.3"
  }
}
