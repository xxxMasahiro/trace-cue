{
  "name": "browser-debug-cli",
  "version": "0.0.0",
  "private": true,
  "description": "Local-first Playwright-based browser debugging CLI for humans and AI agents.",
  "type": "module",
  "bin": {
    "browser-debug": "./bin/browser-debug.js",
    "browser-debug-mcp": "./bin/browser-debug-mcp.js"
  },
  "exports": {
    ".": "./src/api.js",
    "./schemas/*": "./schemas/*.schema.json"
  },
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "doctor": "node ./bin/browser-debug.js doctor --json",
    "test": "node --test tests/architecture.test.js tests/cli.test.js",
    "test:browser": "BROWSER_DEBUG_BROWSER_SMOKE=1 node --test tests/browser-smoke.test.js",
    "test:pack": "node ./tools/pack-dry-run.mjs",
    "test:pack-install": "node ./tools/pack-install-smoke.mjs",
    "release:check": "npm test && npm run test:pack && npm run test:pack-install"
  },
  "files": [
    ".codex-plugin/",
    ".mcp.json",
    "bin/",
    "src/",
    "schemas/",
    "templates/",
    "skills/browser-debug-review/SKILL.md",
    "README.md",
    "CHANGELOG.md",
    "docs/workflow/CONSUMER_USAGE.md",
    "docs/workflow/IDENTITY_MIGRATION.md",
    "docs/workflow/SECURITY.md",
    "docs/workflow/RELEASE.md",
    "docs/workflow/VERIFICATION.md"
  ],
  "keywords": [
    "browser-debugging",
    "playwright",
    "cli",
    "ui-testing",
    "agent-tools"
  ],
  "license": "UNLICENSED",
  "dependencies": {
    "playwright": "^1.61.0"
  }
}
