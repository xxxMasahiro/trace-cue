#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
DEFAULT_ROOT="$(cd "$SCRIPT_DIR/.." && pwd)"
ROOT="$DEFAULT_ROOT"
ACTION="install"
EXPECTED_PATH=".githooks"

while [[ "$#" -gt 0 ]]; do
  case "$1" in
    --repo)
      [[ "$#" -ge 2 ]] || { printf '%s\n' '--repo requires a path.' >&2; exit 2; }
      ROOT="$(cd "$2" && pwd)"
      shift 2
      ;;
    --uninstall)
      ACTION="uninstall"
      shift
      ;;
    *)
      printf 'Unsupported argument: %s\n' "$1" >&2
      exit 2
      ;;
  esac
done

git -C "$ROOT" rev-parse --show-toplevel >/dev/null
current="$(git -C "$ROOT" config --local --get core.hooksPath 2>/dev/null || true)"

if [[ "$ACTION" == "uninstall" ]]; then
  if [[ -z "$current" ]]; then
    printf 'TraceCue Git hooks are not installed.\n'
    exit 0
  fi
  if [[ "$current" != "$EXPECTED_PATH" ]]; then
    printf 'Refusing to remove unmanaged core.hooksPath: %s\n' "$current" >&2
    exit 1
  fi
  git -C "$ROOT" config --local --unset core.hooksPath
  printf 'TraceCue Git hooks uninstalled.\n'
  exit 0
fi

if [[ ! -x "$ROOT/.githooks/pre-push" ]]; then
  printf 'Managed pre-push hook is missing or not executable: .githooks/pre-push\n' >&2
  exit 1
fi
if [[ -n "$current" && "$current" != "$EXPECTED_PATH" ]]; then
  printf 'Refusing to replace unmanaged core.hooksPath: %s\n' "$current" >&2
  exit 1
fi

git -C "$ROOT" config --local core.hooksPath "$EXPECTED_PATH"
printf 'TraceCue Git hooks installed for this repository only.\n'
