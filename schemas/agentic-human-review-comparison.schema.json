{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://trace-cue.local/schemas/agentic-human-review-comparison.schema.json",
  "title": "TraceCue Agentic Human Review Comparison",
  "type": "object",
  "required": [
    "schema_version",
    "type",
    "comparison_version",
    "generated_at",
    "baseline",
    "candidate",
    "deltas",
    "summary",
    "warnings",
    "advisory_only",
    "gate_effect",
    "boundary"
  ],
  "properties": {
    "schema_version": { "type": "string" },
    "type": { "const": "agentic_human_review_comparison" },
    "comparison_version": { "type": "string" },
    "comparison_kind": { "type": "string" },
    "generated_at": { "type": "string" },
    "baseline": { "type": "object" },
    "candidate": { "type": "object" },
    "deltas": { "type": "object" },
    "regression_diagnostics": { "type": "array" },
    "improvement_diagnostics": { "type": "array" },
    "metric_diagnostics": { "type": "array" },
    "summary": { "type": "object" },
    "direct_vs_tracecue_analysis": { "type": ["object", "null"] },
    "editorial_quality_comparison": { "type": ["object", "null"] },
    "warnings": { "type": "array" },
    "advisory_only": { "const": true },
    "gate_effect": { "const": "none" },
    "boundary": { "type": "object" }
  },
  "additionalProperties": true
}
