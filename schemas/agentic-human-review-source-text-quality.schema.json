{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://trace-cue.local/schemas/agentic-human-review-source-text-quality.schema.json",
  "title": "TraceCue Agentic Human Review Source Text Quality",
  "type": "object",
  "required": ["schema_version", "type", "source_text_quality_version", "generated_at", "status", "required_efforts", "effort_results", "effort_matrix", "pass_conditions", "diagnostics", "warnings", "boundary", "advisory_only", "gate_effect"],
  "properties": {
    "schema_version": { "type": "string" },
    "type": { "const": "agentic_human_review_source_text_quality" },
    "source_text_quality_version": { "type": "string" },
    "generated_at": { "type": "string" },
    "status": { "enum": ["ready_for_owner_review", "needs_attention"] },
    "required_efforts": { "type": "array" },
    "observed_efforts": { "type": "array" },
    "source_types": { "type": "array" },
    "effort_results": { "type": "array" },
    "effort_matrix": { "type": "object" },
    "reference_review": { "type": "object" },
    "reference_comparisons": { "type": "array" },
    "pass_conditions": { "type": "object" },
    "diagnostics": { "type": "array" },
    "warnings": { "type": "array" },
    "boundary": { "type": "object" },
    "advisory_only": { "const": true },
    "gate_effect": { "const": "none" }
  },
  "additionalProperties": true
}
