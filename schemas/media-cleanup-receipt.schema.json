{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://trace-cue.local/schemas/media-cleanup-receipt.schema.json",
  "title": "TraceCue Media Cleanup Receipt",
  "type": "object",
  "allOf": [{
    "oneOf": [
      { "properties": { "status": { "const": "already_cleaned" }, "identity": { "type": ["string", "null"], "pattern": "^[a-f0-9]{64}$" } } },
      { "properties": { "status": { "enum": ["cleaned", "refused", "failed"] }, "identity": { "type": "string", "pattern": "^[a-f0-9]{64}$" } } }
    ]
  }],
  "required": ["schema_version", "type", "operation_id", "status", "retention", "reason", "completed_at", "deleted", "identity", "boundary"],
  "properties": {
    "schema_version": { "const": "1.0.0" },
    "type": { "const": "media_cleanup_receipt" },
    "operation_id": { "type": "string", "pattern": "^[a-f0-9]{32}$" },
    "status": { "enum": ["cleaned", "already_cleaned", "refused", "failed"] },
    "retention": { "enum": ["ephemeral", "project-retained"] },
    "reason": { "type": "string", "minLength": 1, "maxLength": 160, "pattern": "^[A-Za-z0-9_]+$" },
    "completed_at": { "type": "string", "format": "date-time" },
    "deleted": {
      "type": "object",
      "required": ["file_count", "directory_count", "byte_count"],
      "properties": {
        "file_count": { "type": "integer", "minimum": 0 },
        "directory_count": { "type": "integer", "minimum": 0 },
        "byte_count": { "type": "integer", "minimum": 0 }
      },
      "additionalProperties": false
    },
    "identity": { "type": ["string", "null"], "pattern": "^[a-f0-9]{64}$" },
    "limitations": { "type": "array", "maxItems": 16, "uniqueItems": true, "items": { "type": "string", "maxLength": 200 } },
    "boundary": {
      "type": "object",
      "required": ["absolute_path_included", "raw_media_included", "full_transcript_included", "sibling_deleted", "normal_artifact_root_deleted"],
      "properties": {
        "absolute_path_included": { "const": false },
        "raw_media_included": { "const": false },
        "full_transcript_included": { "const": false },
        "sibling_deleted": { "const": false },
        "normal_artifact_root_deleted": { "const": false }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
