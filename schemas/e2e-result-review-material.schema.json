{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://trace-cue.local/schemas/e2e-result-review-material.schema.json",
  "title": "TraceCue E2E Result Review Material",
  "type": "object",
  "required": [
    "schema_version",
    "review_material_version",
    "kind",
    "adapter",
    "result",
    "owner_summary",
    "review_cards",
    "evidence_quality",
    "limitations",
    "comparison",
    "next_action",
    "review_input_by_effort",
    "raw_content_included",
    "boundary"
  ],
  "properties": {
    "schema_version": { "type": "string" },
    "review_material_version": { "type": "string" },
    "kind": { "const": "e2e_result_review_material" },
    "adapter": {
      "type": "object",
      "properties": {
        "kind": { "const": "playwright_test" },
        "integration_version": { "type": "string" }
      },
      "additionalProperties": true
    },
    "result": {
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "status": { "type": "string" },
        "source_kind": { "type": "string" },
        "format": { "type": "string" },
        "total_count": { "type": "number" },
        "failed_count": { "type": "number" },
        "raw_content_included": { "const": false }
      },
      "additionalProperties": true
    },
    "owner_summary": { "type": "object" },
    "review_cards": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "type", "status", "title", "body", "owner_action", "evidence_refs"],
        "properties": {
          "id": { "type": "string" },
          "type": { "type": "string" },
          "status": { "type": "string" },
          "title": { "type": "string" },
          "body": { "type": "string" },
          "owner_action": { "type": "string" },
          "evidence_refs": { "type": "array" }
        },
        "additionalProperties": true
      }
    },
    "evidence_quality": {
      "type": "object",
      "properties": {
        "status": { "enum": ["usable", "limited", "missing", "stale"] },
        "signals": { "type": "array" },
        "raw_content_included": { "const": false },
        "source_artifact_body_read": { "const": false }
      },
      "additionalProperties": true
    },
    "limitations": { "type": "array" },
    "comparison": {
      "type": "object",
      "properties": {
        "status": { "enum": ["unavailable", "incompatible", "comparable"] },
        "direction": { "type": "string" },
        "raw_content_included": { "const": false }
      },
      "additionalProperties": true
    },
    "next_action": { "type": "string" },
    "review_input_by_effort": {
      "type": "object",
      "properties": {
        "standard": { "type": "object" },
        "deep": { "type": "object" },
        "xhigh": { "type": "object" }
      },
      "additionalProperties": true
    },
    "raw_content_included": { "const": false },
    "boundary": {
      "type": "object",
      "properties": {
        "local_only": { "const": true },
        "advisory_only": { "const": true },
        "read_only": { "const": true },
        "normalized_result_only": { "const": true },
        "writes_artifacts": { "const": false },
        "review_material_written": { "const": false },
        "provider_call_performed": { "const": false },
        "api_call_performed": { "const": false },
        "browser_launched": { "const": false },
        "process_spawned": { "const": false },
        "network_used": { "const": false },
        "gh_used": { "const": false },
        "raw_artifact_content_included": { "const": false },
        "raw_content_included": { "const": false },
        "mcp_execution_exposed": { "const": false },
        "release_gate_mutated": { "const": false },
        "gate_effect": { "const": "none" }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}
