{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://trace-cue.local/schemas/agentic-human-review-xhigh-completion.schema.json",
  "title": "TraceCue Agentic Human Review XHigh Completion",
  "type": "object",
  "required": [
    "schema_version",
    "completion_version",
    "required",
    "status",
    "mechanical_contract_enforced",
    "required_roles",
    "missing_roles",
    "planned_rounds",
    "missing_rounds",
    "missing_critique_roles",
    "synthesis_integrated",
    "missing_conditions",
    "repair_plan",
    "multi_step_plan",
    "evidence_provenance",
    "advisory_only",
    "gate_effect"
  ],
  "properties": {
    "schema_version": { "type": "string" },
    "completion_version": { "type": "string" },
    "strict_output_contract_version": { "type": "string" },
    "repair_retry_version": { "type": "string" },
    "multi_step_xhigh_version": { "type": "string" },
    "evidence_provenance_version": { "type": "string" },
    "required": { "type": "boolean" },
    "status": { "enum": ["complete", "incomplete", "not_required"] },
    "mechanical_contract_enforced": { "const": true },
    "planned_role_count": { "type": "number" },
    "reported_role_count": { "type": "number" },
    "placeholder_output_count": { "type": "number" },
    "required_roles": { "type": "array" },
    "missing_roles": { "type": "array" },
    "planned_rounds": { "type": "array" },
    "missing_rounds": { "type": "array" },
    "round_mismatch_roles": { "type": "array" },
    "missing_critique_roles": { "type": "array" },
    "synthesis_integrated": { "type": "boolean" },
    "completion_score": { "type": "number" },
    "missing_conditions": { "type": "array" },
    "repair_plan": { "type": "object" },
    "multi_step_plan": { "type": "object" },
    "evidence_provenance": { "type": "object" },
    "strict_output_contract": { "type": ["object", "null"] },
    "provider_effort_binding": { "type": ["object", "null"] },
    "advisory_only": { "const": true },
    "gate_effect": { "const": "none" }
  },
  "additionalProperties": true
}
