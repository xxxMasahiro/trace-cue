{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://trace-cue.local/schemas/content-evidence.schema.json",
  "title": "TraceCue Content Evidence",
  "type": "object",
  "required": ["schema_version", "evidence_kind", "source_type"],
  "properties": {
    "schema_version": { "type": "string" },
    "evidence_version": { "type": "string" },
    "evidence_kind": { "const": "content_evidence" },
    "id": { "type": "string" },
    "status": { "enum": ["available", "insufficient", "not_supplied"] },
    "source_type": {
      "enum": ["video", "web_page", "pdf", "meeting_notes", "document", "transcript", "other"]
    },
    "source": { "type": ["object", "null"] },
    "provider": { "type": ["object", "null"] },
    "summaries": { "type": "object" },
    "content_units": { "type": "array" },
    "claims_observed": { "type": "array" },
    "limitations": { "type": "array" },
    "coverage": { "type": "object" },
    "provenance": { "type": ["object", "null"] },
    "privacy": { "type": ["object", "null"] },
    "boundary": { "type": "object" },
    "advisory_only": { "const": true },
    "gate_effect": { "const": "none" }
  },
  "additionalProperties": true
}
