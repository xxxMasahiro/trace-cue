{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://trace-cue.local/schemas/media-review-comparison-policy.schema.json",
  "title": "TraceCue Media Review Comparison Policy",
  "type": "object",
  "required": ["schema_version", "policy_version", "accepted_result_schema_versions", "input", "matching", "metrics", "output", "boundary"],
  "properties": {
    "schema_version": { "const": "1.0.0" },
    "policy_version": { "type": "string", "pattern": "^1\\.[0-9]+\\.[0-9]+$" },
    "accepted_result_schema_versions": {
      "type": "array",
      "minItems": 1,
      "maxItems": 8,
      "uniqueItems": true,
      "items": { "type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$" }
    },
    "input": {
      "type": "object",
      "required": ["maximum_result_bytes", "maximum_total_input_bytes", "maximum_findings_per_class", "producer_finding_limits"],
      "properties": {
        "maximum_result_bytes": { "type": "integer", "minimum": 1024 },
        "maximum_total_input_bytes": { "type": "integer", "minimum": 2048 },
        "maximum_findings_per_class": { "type": "integer", "minimum": 1, "maximum": 1000 },
        "producer_finding_limits": {
          "type": "array",
          "minItems": 1,
          "maxItems": 32,
          "items": {
            "type": "object",
            "required": ["policy_identity", "maximum_total_findings"],
            "properties": {
              "policy_identity": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
              "maximum_total_findings": { "type": "integer", "minimum": 1, "maximum": 1000 }
            },
            "additionalProperties": false
          }
        }
      },
      "additionalProperties": false
    },
    "matching": {
      "type": "object",
      "required": ["stable_timing_tolerance_us", "maximum_moved_timing_distance_us", "minimum_overlap_ratio", "confidence_change_threshold"],
      "properties": {
        "stable_timing_tolerance_us": { "type": "integer", "minimum": 0 },
        "maximum_moved_timing_distance_us": { "type": "integer", "minimum": 0 },
        "minimum_overlap_ratio": { "type": "number", "minimum": 0, "maximum": 1 },
        "confidence_change_threshold": { "type": "number", "minimum": 0, "maximum": 1 }
      },
      "additionalProperties": false
    },
    "metrics": {
      "type": "array",
      "minItems": 1,
      "maxItems": 32,
      "items": {
        "type": "object",
        "required": ["id", "domain", "classification", "selector", "unit", "quality_direction", "tolerance", "normalize_per_minute"],
        "properties": {
          "id": { "type": "string", "pattern": "^[a-z0-9_]{1,100}$" },
          "domain": { "enum": ["technical", "transcript", "advisory"] },
          "classification": { "enum": ["deterministic_measurement", "provider_measurement", "advisory_evaluation"] },
          "selector": { "type": "string", "pattern": "^[a-z0-9_.]{1,200}$" },
          "unit": { "type": "string", "pattern": "^[a-z0-9_]{1,80}$" },
          "quality_direction": { "enum": ["lower_is_better", "higher_is_better", "informational"] },
          "tolerance": { "type": "number", "minimum": 0 },
          "normalize_per_minute": { "type": "boolean" }
        },
        "oneOf": [
          {
            "properties": {
              "domain": { "const": "technical" },
              "classification": { "const": "deterministic_measurement" }
            }
          },
          {
            "properties": {
              "domain": { "const": "transcript" },
              "classification": { "const": "provider_measurement" }
            }
          },
          {
            "properties": {
              "domain": { "const": "advisory" },
              "classification": { "const": "advisory_evaluation" }
            }
          }
        ],
        "additionalProperties": false
      }
    },
    "output": {
      "type": "object",
      "required": ["maximum_result_bytes", "maximum_metric_diffs", "maximum_finding_changes", "maximum_limitations"],
      "properties": {
        "maximum_result_bytes": { "type": "integer", "minimum": 1024 },
        "maximum_metric_diffs": { "type": "integer", "minimum": 1, "maximum": 128 },
        "maximum_finding_changes": { "type": "integer", "minimum": 1, "maximum": 1000 },
        "maximum_limitations": { "type": "integer", "minimum": 1, "maximum": 256 }
      },
      "additionalProperties": false
    },
    "boundary": {
      "type": "object",
      "required": ["public_results_only", "raw_media_read", "raw_audio_read", "raw_frames_read", "full_transcript_read", "private_operation_read", "provider_execution", "technical_analyzer_execution", "network_performed", "external_send_performed", "mcp_execution_exposed", "combined_quality_score"],
      "properties": {
        "public_results_only": { "const": true },
        "raw_media_read": { "const": false },
        "raw_audio_read": { "const": false },
        "raw_frames_read": { "const": false },
        "full_transcript_read": { "const": false },
        "private_operation_read": { "const": false },
        "provider_execution": { "const": false },
        "technical_analyzer_execution": { "const": false },
        "network_performed": { "const": false },
        "external_send_performed": { "const": false },
        "mcp_execution_exposed": { "const": false },
        "combined_quality_score": { "const": false }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
