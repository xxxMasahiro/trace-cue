{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://trace-cue.local/schemas/media-review-result.schema.json",
  "title": "TraceCue Media Review Result",
  "$defs": {
    "identity": {
      "type": "object",
      "required": ["sha256", "bytes", "format"],
      "properties": {
        "sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
        "bytes": { "type": "integer", "minimum": 1 },
        "format": { "type": "string", "minLength": 1, "maxLength": 80 }
      },
      "additionalProperties": false
    },
    "findingBase": {
      "type": "object",
      "required": ["schema_version", "id", "kind", "start_us", "end_us", "timecode", "severity", "evidence", "evidence_refs", "method", "confidence", "classification", "limitations", "recommendation", "recommendation_classification", "scene_reference"],
      "properties": {
        "schema_version": { "const": "1.0.0" },
        "id": { "type": "string", "pattern": "^media-finding-[a-f0-9]{16}$" },
        "kind": { "type": "string", "pattern": "^[a-z0-9_]{1,100}$" },
        "start_us": { "type": "integer", "minimum": 0 },
        "end_us": { "type": "integer", "minimum": 0 },
        "timecode": {
          "type": "object", "required": ["start", "end"],
          "properties": { "start": { "type": "string", "pattern": "^[0-9]{2,}:[0-9]{2}:[0-9]{2}\\.[0-9]{3}$" }, "end": { "type": "string", "pattern": "^[0-9]{2,}:[0-9]{2}:[0-9]{2}\\.[0-9]{3}$" } },
          "additionalProperties": false
        },
        "severity": { "enum": ["low", "medium", "high", "critical"] },
        "evidence": { "type": "array", "maxItems": 6, "items": { "type": "string", "maxLength": 1000 } },
        "evidence_refs": { "type": "array", "maxItems": 8, "items": { "type": "string", "maxLength": 200 } },
        "method": { "type": "string", "pattern": "^[a-z0-9_]{1,120}$" },
        "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
        "classification": { "enum": ["deterministic_measurement", "advisory_evaluation"] },
        "limitations": { "type": "array", "items": { "type": "string", "maxLength": 500 } },
        "recommendation": { "type": "string", "maxLength": 1000 },
        "recommendation_classification": { "const": "advisory_evaluation" },
        "scene_reference": {
          "type": "object", "required": ["start_us", "end_us"],
          "properties": { "start_us": { "type": "integer", "minimum": 0 }, "end_us": { "type": "integer", "minimum": 0 } },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    },
    "deterministicFinding": { "allOf": [{ "$ref": "#/$defs/findingBase" }, { "properties": { "classification": { "const": "deterministic_measurement" } } }] },
    "advisoryFinding": { "allOf": [{ "$ref": "#/$defs/findingBase" }, { "properties": { "classification": { "const": "advisory_evaluation" } } }] },
    "falseBoundary": {
      "type": "object",
      "required": ["absolute_paths_included", "raw_media_included", "raw_audio_included", "raw_frames_included", "full_transcript_included", "raw_process_output_included", "url_query_or_fragment_included", "external_send_enabled", "cloud_asr_enabled", "mcp_execution_enabled", "deterministic_and_advisory_separated", "failure_treated_as_success"],
      "properties": {
        "absolute_paths_included": { "const": false }, "raw_media_included": { "const": false },
        "raw_audio_included": { "const": false }, "raw_frames_included": { "const": false },
        "full_transcript_included": { "const": false }, "raw_process_output_included": { "const": false },
        "url_query_or_fragment_included": { "const": false }, "external_send_enabled": { "const": false },
        "cloud_asr_enabled": { "const": false }, "mcp_execution_enabled": { "const": false },
        "deterministic_and_advisory_separated": { "const": true }, "failure_treated_as_success": { "const": false }
      },
      "additionalProperties": false
    },
    "resourceGuard": {
      "type": "object",
      "required": ["mode", "enabled", "status", "checks", "warnings", "stop_on_critical", "boundary"],
      "properties": {
        "mode": { "enum": ["advisory", "fail-critical", "off"] }, "enabled": { "type": "boolean" },
        "status": { "enum": ["ok", "watch", "critical", "not_checked", "off"] }, "stop_on_critical": { "type": "boolean" },
        "checks": {
          "type": "array", "maxItems": 8,
          "items": {
            "type": "object",
            "required": ["stage", "status", "observed_at", "source", "recommended_action", "details", "memory", "cgroup", "pressure"],
            "properties": {
              "stage": { "type": "string", "pattern": "^[a-z0-9_]{1,100}$" }, "status": { "enum": ["ok", "watch", "critical", "unavailable"] },
              "observed_at": { "type": "string", "format": "date-time" }, "source": { "type": "string", "maxLength": 100 },
              "recommended_action": { "type": "string", "maxLength": 200 },
              "details": {
                "type": "object",
                "properties": { "maximum_media_bytes": { "type": "integer", "minimum": 0 }, "frame_count": { "type": "integer", "minimum": 0 }, "finding_count": { "type": "integer", "minimum": 0 } },
                "additionalProperties": false
              },
              "memory": {
                "type": "object", "required": ["available_bytes", "available_ratio", "swap_used_bytes", "swap_used_ratio"],
                "properties": { "available_bytes": { "type": ["integer", "null"], "minimum": 0 }, "available_ratio": { "type": ["number", "null"], "minimum": 0, "maximum": 1 }, "swap_used_bytes": { "type": ["integer", "null"], "minimum": 0 }, "swap_used_ratio": { "type": ["number", "null"], "minimum": 0, "maximum": 1 } },
                "additionalProperties": false
              },
              "cgroup": {
                "type": "object", "required": ["available", "current_bytes", "limit_bytes", "usage_ratio"],
                "properties": { "available": { "type": "boolean" }, "current_bytes": { "type": ["integer", "null"], "minimum": 0 }, "limit_bytes": { "type": ["integer", "null"], "minimum": 0 }, "usage_ratio": { "type": ["number", "null"], "minimum": 0 } },
                "additionalProperties": false
              },
              "pressure": {
                "type": "object", "required": ["available", "some_avg10", "full_avg10"],
                "properties": { "available": { "type": "boolean" }, "some_avg10": { "type": ["number", "null"], "minimum": 0 }, "full_avg10": { "type": ["number", "null"], "minimum": 0 } },
                "additionalProperties": false
              }
            },
            "additionalProperties": false
          }
        },
        "warnings": {
          "type": "array", "maxItems": 16,
          "items": {
            "type": "object", "required": ["code", "message", "details"],
            "properties": { "code": { "type": "string", "pattern": "^[A-Z0-9_]{2,100}$" }, "message": { "type": "string", "maxLength": 500 }, "details": { "type": "object", "properties": { "stage": { "type": "string", "maxLength": 100 }, "recommended_action": { "type": "string", "maxLength": 200 } }, "additionalProperties": false } },
            "additionalProperties": false
          }
        },
        "boundary": {
          "type": "object",
          "required": ["local_only", "browser_launched_by_guard", "external_upload", "profile_reuse", "system_cache_mutated", "swap_mutated", "cache_deleted", "privileged_helper_used", "shell_used"],
          "properties": { "local_only": { "const": true }, "browser_launched_by_guard": { "const": false }, "external_upload": { "const": false }, "profile_reuse": { "const": false }, "system_cache_mutated": { "const": false }, "swap_mutated": { "const": false }, "cache_deleted": { "const": false }, "privileged_helper_used": { "const": false }, "shell_used": { "const": false } },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    },
    "contentEvidence": {
      "type": "object",
      "required": ["schema_version", "evidence_version", "evidence_kind", "id", "status", "source_type", "source", "provider", "summaries", "content_units", "claims_observed", "limitations", "coverage", "provenance", "privacy", "boundary", "advisory_only", "gate_effect"],
      "properties": {
        "schema_version": { "const": "1.0.0" }, "evidence_version": { "const": "1.0.0" }, "evidence_kind": { "const": "content_evidence" },
        "id": { "type": "string", "pattern": "^media-content-[a-f0-9]{16}$" }, "status": { "enum": ["available", "insufficient"] }, "source_type": { "const": "video" },
        "source": {
          "type": "object", "required": ["kind", "title", "locator", "media_id", "duration_seconds", "page_count"],
          "properties": { "kind": { "const": "local_media_review" }, "title": { "const": null }, "locator": { "const": null }, "media_id": { "type": "string", "pattern": "^[a-f0-9]{64}$" }, "duration_seconds": { "type": "number", "minimum": 0 }, "page_count": { "const": null } },
          "additionalProperties": false
        },
        "provider": {
          "type": "object", "required": ["id", "kind", "version", "local_execution_declared", "api_call_declared"],
          "properties": { "id": { "const": "trace-cue-media-review" }, "kind": { "const": "local_cross_modal_review" }, "version": { "const": "1.0.0" }, "local_execution_declared": { "const": true }, "api_call_declared": { "const": false } },
          "additionalProperties": false
        },
        "summaries": {
          "type": "object", "required": ["content_summary", "transcript_summary", "visible_text_summary", "section_summary"],
          "properties": { "content_summary": { "type": "array", "items": { "type": "string", "maxLength": 1000 } }, "transcript_summary": { "type": "array", "items": { "type": "string", "maxLength": 1000 } }, "visible_text_summary": { "type": "array", "items": { "type": "string", "maxLength": 1000 } }, "section_summary": { "type": "array", "items": { "type": "string", "maxLength": 1000 } } },
          "additionalProperties": false
        },
        "content_units": {
          "type": "array",
          "items": {
            "type": "object", "required": ["id", "unit_type", "locator", "text", "summary", "source_refs", "confidence"],
            "properties": { "id": { "type": "string", "maxLength": 240 }, "unit_type": { "const": "media_review_finding" }, "locator": { "type": "string", "maxLength": 80 }, "text": { "type": "string", "maxLength": 1000 }, "summary": { "type": "string", "maxLength": 700 }, "source_refs": { "type": "array", "items": { "type": "string", "maxLength": 200 } }, "confidence": { "enum": ["low", "medium", "high"] } },
            "additionalProperties": false
          }
        },
        "claims_observed": { "type": "array", "maxItems": 0 },
        "limitations": { "type": "array", "items": { "type": "string", "maxLength": 200 } },
        "coverage": {
          "type": "object", "required": ["source_type", "content_understanding_level", "has_summary", "has_bounded_units", "has_original_text", "has_full_text", "has_location_refs", "original_text_coverage_score", "location_reference_coverage_score", "advisory_only", "gate_effect"],
          "properties": { "source_type": { "const": "video" }, "content_understanding_level": { "enum": ["multimodal", "metadata"] }, "has_summary": { "const": true }, "has_bounded_units": { "type": "boolean" }, "has_original_text": { "type": "boolean" }, "has_full_text": { "const": false }, "has_location_refs": { "const": true }, "original_text_coverage_score": { "type": "number", "minimum": 0, "maximum": 1 }, "location_reference_coverage_score": { "type": "number", "minimum": 0, "maximum": 1 }, "advisory_only": { "const": true }, "gate_effect": { "const": "none" } },
          "additionalProperties": false
        },
        "provenance": {
          "type": "object", "required": ["input_path", "input_hash", "input_type", "generated_at", "source_tool"],
          "properties": { "input_path": { "const": null }, "input_hash": { "type": "string", "pattern": "^[a-f0-9]{64}$" }, "input_type": { "const": "local_media" }, "generated_at": { "const": null }, "source_tool": { "const": "trace-cue-media-review" } },
          "additionalProperties": false
        },
        "privacy": {
          "type": "object", "required": ["raw_media_embedded_in_json", "raw_binary_embedded_in_json", "raw_html_embedded_in_json", "raw_pdf_embedded_in_json", "full_transcript_embedded_in_json", "full_document_embedded_in_json", "bounded_text_units_only"],
          "properties": { "raw_media_embedded_in_json": { "const": false }, "raw_binary_embedded_in_json": { "const": false }, "raw_html_embedded_in_json": { "const": false }, "raw_pdf_embedded_in_json": { "const": false }, "full_transcript_embedded_in_json": { "const": false }, "full_document_embedded_in_json": { "const": false }, "bounded_text_units_only": { "const": true } },
          "additionalProperties": false
        },
        "boundary": {
          "type": "object", "required": ["raw_media_included", "raw_binary_included", "full_transcript_included", "external_send_performed", "bounded_text_only"],
          "properties": { "raw_media_included": { "const": false }, "raw_binary_included": { "const": false }, "full_transcript_included": { "const": false }, "external_send_performed": { "const": false }, "bounded_text_only": { "const": true } },
          "additionalProperties": false
        },
        "advisory_only": { "const": true }, "gate_effect": { "const": "none" }
      },
      "additionalProperties": false
    }
  },
  "type": "object",
  "required": ["schema_version", "type", "operation_id", "status", "media_identity", "source_decision", "analysis_settings", "toolchain", "technical_analysis", "transcript", "timeline", "deterministic_findings", "advisory_findings", "content_evidence", "limitations", "resource_guard", "privacy", "boundary"],
  "properties": {
    "schema_version": { "const": "1.0.0" }, "type": { "const": "media_review_result" },
    "operation_id": { "type": "string", "pattern": "^[a-f0-9]{32}$" },
    "status": { "enum": ["completed", "completed_with_limitations", "insufficient"] },
    "media_identity": { "$ref": "#/$defs/identity" },
    "source_decision": { "$ref": "media-source-decision.schema.json" },
    "analysis_settings": {
      "type": "object",
      "required": ["schema_version", "policy_version", "maximum_media_bytes", "maximum_duration_us", "maximum_frames", "cut_scene_threshold", "av_sync_warning_us", "subtitle_minimum_us", "duplicate_hash_window", "maximum_subtitle_events", "maximum_total_streams", "maximum_video_streams", "maximum_audio_streams", "maximum_subtitle_streams", "maximum_video_width", "maximum_video_height", "maximum_video_pixels", "maximum_audio_sample_rate", "maximum_audio_channels", "decoder_threads", "maximum_single_allocation_bytes", "speech_cut_edge_margin_us", "topic_change_visual_window_us", "long_pause_warning_us", "speech_density_warning_words_per_second", "speech_density_high_words_per_second", "repetition_similarity_threshold", "policy_identity", "semantic_change_method", "deterministic_and_advisory_separated"],
      "properties": {
        "schema_version": { "const": "1.0.0" }, "policy_version": { "type": "string", "maxLength": 40 },
        "maximum_media_bytes": { "type": "integer", "minimum": 1 }, "maximum_duration_us": { "type": "integer", "minimum": 1 },
        "maximum_frames": { "type": "integer", "minimum": 1 }, "cut_scene_threshold": { "type": "number", "minimum": 0, "maximum": 1 },
        "av_sync_warning_us": { "type": "integer", "minimum": 0 }, "subtitle_minimum_us": { "type": "integer", "minimum": 0 },
        "duplicate_hash_window": { "type": "integer", "minimum": 1 }, "maximum_subtitle_events": { "type": "integer", "minimum": 1 },
        "maximum_total_streams": { "type": "integer", "minimum": 1 }, "maximum_video_streams": { "type": "integer", "minimum": 1 },
        "maximum_audio_streams": { "type": "integer", "minimum": 1 }, "maximum_subtitle_streams": { "type": "integer", "minimum": 1 },
        "maximum_video_width": { "type": "integer", "minimum": 1 }, "maximum_video_height": { "type": "integer", "minimum": 1 },
        "maximum_video_pixels": { "type": "integer", "minimum": 1 }, "maximum_audio_sample_rate": { "type": "integer", "minimum": 1 },
        "maximum_audio_channels": { "type": "integer", "minimum": 1 }, "decoder_threads": { "type": "integer", "minimum": 1 },
        "maximum_single_allocation_bytes": { "type": "integer", "minimum": 1 },
        "speech_cut_edge_margin_us": { "type": "integer", "minimum": 0 }, "topic_change_visual_window_us": { "type": "integer", "minimum": 0 },
        "long_pause_warning_us": { "type": "integer", "minimum": 0 }, "speech_density_warning_words_per_second": { "type": "number", "minimum": 0 },
        "speech_density_high_words_per_second": { "type": "number", "minimum": 0 }, "repetition_similarity_threshold": { "type": "number", "minimum": 0, "maximum": 1 },
        "policy_identity": { "type": "string", "pattern": "^[a-f0-9]{64}$" }, "semantic_change_method": { "const": "token_jaccard_heuristic" },
        "deterministic_and_advisory_separated": { "const": true }
      },
      "additionalProperties": false
    },
    "toolchain": {
      "type": "object", "required": ["transcript_provider", "technical_analyzer", "comparable_configuration_identity"],
      "properties": { "transcript_provider": { "$ref": "transcript-provider.schema.json#/$defs/method" }, "technical_analyzer": { "$ref": "media-analysis.schema.json#/properties/method" }, "comparable_configuration_identity": { "type": "string", "pattern": "^[a-f0-9]{64}$" } },
      "additionalProperties": false
    },
    "technical_analysis": { "$ref": "media-analysis.schema.json" },
    "transcript": { "$ref": "transcript-provider.schema.json" },
    "timeline": { "$ref": "media-timeline.schema.json" },
    "deterministic_findings": { "type": "array", "items": { "$ref": "#/$defs/deterministicFinding" } },
    "advisory_findings": { "type": "array", "items": { "$ref": "#/$defs/advisoryFinding" } },
    "content_evidence": { "$ref": "#/$defs/contentEvidence" },
    "resource_guard": { "$ref": "#/$defs/resourceGuard" },
    "limitations": { "type": "array", "items": { "type": "string", "maxLength": 300 }, "uniqueItems": true },
    "privacy": {
      "type": "object",
      "required": ["retention", "private_payload_retained", "raw_media_persisted_outside_private_root", "full_transcript_persisted_outside_private_root", "full_transcript_in_result", "raw_audio_in_result", "raw_frames_in_result", "external_send_performed"],
      "properties": {
        "retention": { "enum": ["ephemeral", "project-retained"] }, "private_payload_retained": { "type": "boolean" },
        "raw_media_persisted_outside_private_root": { "const": false }, "full_transcript_persisted_outside_private_root": { "const": false },
        "full_transcript_in_result": { "const": false }, "raw_audio_in_result": { "const": false }, "raw_frames_in_result": { "const": false }, "external_send_performed": { "const": false }
      },
      "additionalProperties": false
    },
    "boundary": { "$ref": "#/$defs/falseBoundary" }
  },
  "additionalProperties": false
}
