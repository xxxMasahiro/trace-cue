{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://trace-cue.local/schemas/agentic-human-review-longitudinal-quality.schema.json",
  "title": "TraceCue Agentic Human Review Longitudinal Quality",
  "type": "object",
  "required": ["schema_version", "type", "longitudinal_quality_version", "generated_at", "evidence_set_path", "status", "longitudinal_stability_score", "claim_policy", "warnings", "boundary", "advisory_only", "gate_effect"],
  "properties": {
    "schema_version": { "type": "string" },
    "type": { "const": "agentic_human_review_longitudinal_quality" },
    "longitudinal_quality_version": { "type": "string" },
    "generated_at": { "type": "string" },
    "evidence_set_path": { "type": "string" },
    "status": { "type": "string" },
    "longitudinal_stability_score": { "type": "number" },
    "claim_policy": { "type": "object" },
    "owner_review_context": { "type": "object" },
    "warnings": { "type": "array" },
    "boundary": { "type": "object" },
    "advisory_only": { "const": true },
    "gate_effect": { "const": "none" }
  },
  "additionalProperties": true
