{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://trace-cue.local/schemas/media-review-policy.schema.json",
  "title": "TraceCue Media Review Policy",
  "$defs": {
    "positiveInteger": { "type": "integer", "minimum": 1 },
    "falseFlag": { "const": false }
  },
  "type": "object",
  "required": ["schema_version", "policy_version", "mode", "source", "retention", "operation", "transcript_provider", "technical_analyzer", "reviewer", "public_boundary"],
  "properties": {
    "schema_version": { "const": "1.0.0" },
    "policy_version": { "type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$" },
    "mode": { "const": "local_first" },
    "source": {
      "type": "object",
      "required": ["url_classification_network_enabled", "url_acquisition_enabled", "allowed_url_schemes", "reject_ip_literal_urls", "blocked_hostname_suffixes", "official_player_rules", "maximum_url_characters", "maximum_local_media_bytes", "maximum_media_duration_us", "upload_timeout_ms", "allowed_local_extensions"],
      "properties": {
        "url_classification_network_enabled": { "$ref": "#/$defs/falseFlag" },
        "url_acquisition_enabled": { "$ref": "#/$defs/falseFlag" },
        "allowed_url_schemes": { "const": ["https:"] },
        "reject_ip_literal_urls": { "const": true },
        "blocked_hostname_suffixes": { "type": "array", "minItems": 1, "maxItems": 64, "uniqueItems": true, "items": { "type": "string", "pattern": "^\\.[a-z0-9.-]+$" } },
        "official_player_rules": {
          "type": "array",
          "minItems": 1,
          "maxItems": 32,
          "items": {
            "type": "object",
            "required": ["rule_id", "hosts", "service_kind", "display_path", "identifier_pattern", "identifier_sources"],
            "properties": {
              "rule_id": { "type": "string", "pattern": "^[a-z0-9][a-z0-9-]{2,80}$" },
              "hosts": { "type": "array", "minItems": 1, "maxItems": 32, "uniqueItems": true, "items": { "type": "string", "pattern": "^[a-z0-9.-]+$" } },
              "service_kind": { "type": "string", "pattern": "^[a-z0-9][a-z0-9_]{1,79}$" },
              "display_path": { "type": "string", "pattern": "^/[A-Za-z0-9._~/-]{0,79}$" },
              "identifier_pattern": { "type": "string", "minLength": 1, "maxLength": 160 },
              "identifier_sources": {
                "type": "array",
                "minItems": 1,
                "maxItems": 16,
                "items": {
                  "oneOf": [
                    {
                      "type": "object",
                      "required": ["kind", "key", "exact_path"],
                      "properties": {
                        "kind": { "const": "query" },
                        "key": { "type": "string", "pattern": "^[A-Za-z0-9._~-]{1,40}$" },
                        "exact_path": { "type": "string", "pattern": "^/[A-Za-z0-9._~/-]{0,79}$" }
                      },
                      "additionalProperties": false
                    },
                    {
                      "type": "object",
                      "required": ["kind", "index"],
                      "properties": {
                        "kind": { "const": "path_segment" },
                        "index": { "type": "integer", "minimum": 0, "maximum": 16 },
                        "hosts": { "type": "array", "minItems": 1, "maxItems": 32, "uniqueItems": true, "items": { "type": "string", "pattern": "^[a-z0-9.-]+$" } },
                        "prefixes": { "type": "array", "minItems": 1, "maxItems": 16, "uniqueItems": true, "items": { "type": "string", "pattern": "^[A-Za-z0-9._~-]{1,40}$" } }
                      },
                      "additionalProperties": false
                    },
                    {
                      "type": "object",
                      "required": ["kind"],
                      "properties": { "kind": { "const": "last_matching_path_segment" } },
                      "additionalProperties": false
                    }
                  ]
                }
              }
            },
            "additionalProperties": false
          }
        },
        "maximum_url_characters": { "$ref": "#/$defs/positiveInteger" },
        "maximum_local_media_bytes": { "$ref": "#/$defs/positiveInteger" },
        "maximum_media_duration_us": { "$ref": "#/$defs/positiveInteger" },
        "upload_timeout_ms": { "$ref": "#/$defs/positiveInteger" },
        "allowed_local_extensions": { "type": "array", "minItems": 1, "maxItems": 64, "uniqueItems": true, "items": { "type": "string", "pattern": "^\\.[a-z0-9]{1,8}$" } }
      },
      "additionalProperties": false
    },
    "retention": {
      "type": "object",
      "required": ["default_mode", "allowed_modes", "ephemeral_ttl_ms", "project_retained_ttl_ms", "private_directory_mode", "private_file_mode", "full_transcript_outside_private_root_allowed", "raw_media_outside_private_root_allowed"],
      "properties": {
        "default_mode": { "const": "ephemeral" },
        "allowed_modes": { "type": "array", "minItems": 2, "maxItems": 2, "uniqueItems": true, "items": { "enum": ["ephemeral", "project-retained"] }, "allOf": [{ "contains": { "const": "ephemeral" } }, { "contains": { "const": "project-retained" } }] },
        "ephemeral_ttl_ms": { "$ref": "#/$defs/positiveInteger" },
        "project_retained_ttl_ms": { "$ref": "#/$defs/positiveInteger" },
        "private_directory_mode": { "const": "0700" },
        "private_file_mode": { "const": "0600" },
        "full_transcript_outside_private_root_allowed": { "$ref": "#/$defs/falseFlag" },
        "raw_media_outside_private_root_allowed": { "$ref": "#/$defs/falseFlag" }
      },
      "additionalProperties": false
    },
    "operation": {
      "type": "object",
      "required": ["maximum_active_operations", "maximum_history_operations", "maximum_private_tree_entries", "maximum_private_tree_bytes", "maximum_private_tree_depth", "maximum_findings", "maximum_timeline_items", "maximum_public_excerpt_characters", "maximum_public_result_bytes", "cleanup_retry_delay_ms"],
      "properties": {
        "maximum_active_operations": { "$ref": "#/$defs/positiveInteger" },
        "maximum_history_operations": { "$ref": "#/$defs/positiveInteger" },
        "maximum_private_tree_entries": { "$ref": "#/$defs/positiveInteger" },
        "maximum_private_tree_bytes": { "$ref": "#/$defs/positiveInteger" },
        "maximum_private_tree_depth": { "$ref": "#/$defs/positiveInteger" },
        "maximum_findings": { "$ref": "#/$defs/positiveInteger" },
        "maximum_timeline_items": { "$ref": "#/$defs/positiveInteger" },
        "maximum_public_excerpt_characters": { "$ref": "#/$defs/positiveInteger" },
        "maximum_public_result_bytes": { "$ref": "#/$defs/positiveInteger" },
        "cleanup_retry_delay_ms": { "$ref": "#/$defs/positiveInteger" }
      },
      "additionalProperties": false
    },
    "transcript_provider": {
      "type": "object",
      "required": ["adapter_catalog_relative", "local_profile_relative", "local_profile_environment", "maximum_segments", "maximum_transcript_bytes", "maximum_line_bytes", "maximum_timeline_overrun_us", "readiness_timeout_ms", "stage_timeout_ms", "execution_timeout_ms", "maximum_stdout_bytes", "maximum_stderr_bytes"],
      "properties": {
        "adapter_catalog_relative": { "type": "string", "pattern": "^(?!/)(?!.*(?:^|[\\/])\\.\\.(?:[\\/]|$)).+$" },
        "local_profile_relative": { "type": "string", "pattern": "^(?!/)(?!.*(?:^|[\\/])\\.\\.(?:[\\/]|$)).+$" },
        "local_profile_environment": { "type": "string", "pattern": "^[A-Z_][A-Z0-9_]{2,100}$" },
        "maximum_segments": { "$ref": "#/$defs/positiveInteger" },
        "maximum_transcript_bytes": { "$ref": "#/$defs/positiveInteger" },
        "maximum_line_bytes": { "$ref": "#/$defs/positiveInteger" },
        "maximum_timeline_overrun_us": { "$ref": "#/$defs/positiveInteger" },
        "readiness_timeout_ms": { "$ref": "#/$defs/positiveInteger" },
        "stage_timeout_ms": { "$ref": "#/$defs/positiveInteger" },
        "execution_timeout_ms": { "$ref": "#/$defs/positiveInteger" },
        "maximum_stdout_bytes": { "$ref": "#/$defs/positiveInteger" },
        "maximum_stderr_bytes": { "$ref": "#/$defs/positiveInteger" }
      },
      "additionalProperties": false
    },
    "technical_analyzer": {
      "type": "object",
      "required": ["probe_executable_environment", "analyzer_executable_environment", "probe_candidates", "analyzer_candidates", "maximum_frames", "maximum_subtitle_events", "maximum_total_streams", "maximum_video_streams", "maximum_audio_streams", "maximum_subtitle_streams", "maximum_video_width", "maximum_video_height", "maximum_video_pixels", "maximum_audio_sample_rate", "maximum_audio_channels", "decoder_threads", "maximum_single_allocation_bytes", "timeout_ms", "maximum_stdout_bytes", "maximum_stderr_bytes", "cut_scene_threshold", "duplicate_hash_window", "dropped_interval_multiplier", "interval_jitter_warning_ratio", "av_sync_warning_us", "subtitle_minimum_us"],
      "properties": {
        "probe_executable_environment": { "type": "string", "pattern": "^[A-Z_][A-Z0-9_]{2,100}$" },
        "analyzer_executable_environment": { "type": "string", "pattern": "^[A-Z_][A-Z0-9_]{2,100}$" },
        "probe_candidates": { "type": "array", "minItems": 1, "uniqueItems": true, "items": { "type": "string", "pattern": "^/.*/ffprobe$" } },
        "analyzer_candidates": { "type": "array", "minItems": 1, "uniqueItems": true, "items": { "type": "string", "pattern": "^/.*/ffmpeg$" } },
        "maximum_frames": { "$ref": "#/$defs/positiveInteger" },
        "maximum_subtitle_events": { "$ref": "#/$defs/positiveInteger" },
        "maximum_total_streams": { "$ref": "#/$defs/positiveInteger" },
        "maximum_video_streams": { "$ref": "#/$defs/positiveInteger" },
        "maximum_audio_streams": { "$ref": "#/$defs/positiveInteger" },
        "maximum_subtitle_streams": { "$ref": "#/$defs/positiveInteger" },
        "maximum_video_width": { "$ref": "#/$defs/positiveInteger" },
        "maximum_video_height": { "$ref": "#/$defs/positiveInteger" },
        "maximum_video_pixels": { "$ref": "#/$defs/positiveInteger" },
        "maximum_audio_sample_rate": { "$ref": "#/$defs/positiveInteger" },
        "maximum_audio_channels": { "$ref": "#/$defs/positiveInteger" },
        "decoder_threads": { "$ref": "#/$defs/positiveInteger" },
        "maximum_single_allocation_bytes": { "$ref": "#/$defs/positiveInteger" },
        "timeout_ms": { "$ref": "#/$defs/positiveInteger" },
        "maximum_stdout_bytes": { "$ref": "#/$defs/positiveInteger" },
        "maximum_stderr_bytes": { "$ref": "#/$defs/positiveInteger" },
        "cut_scene_threshold": { "type": "number", "minimum": 0, "maximum": 1 },
        "duplicate_hash_window": { "$ref": "#/$defs/positiveInteger" },
        "dropped_interval_multiplier": { "type": "number", "exclusiveMinimum": 1, "maximum": 100 },
        "interval_jitter_warning_ratio": { "type": "number", "minimum": 0, "maximum": 10 },
        "av_sync_warning_us": { "$ref": "#/$defs/positiveInteger" },
        "subtitle_minimum_us": { "$ref": "#/$defs/positiveInteger" }
      },
      "additionalProperties": false
    },
    "reviewer": {
      "type": "object",
      "required": ["speech_cut_edge_margin_us", "topic_change_similarity_threshold", "topic_change_visual_window_us", "long_pause_warning_us", "long_pause_high_us", "speech_density_warning_words_per_second", "speech_density_high_words_per_second", "repetition_similarity_threshold", "event_aggregation_gap_us", "maximum_content_units", "maximum_content_excerpt_characters", "maximum_single_excerpt_characters", "minimum_excerpt_characters", "maximum_semantic_text_characters", "excerpt_fraction_limit"],
      "properties": {
        "speech_cut_edge_margin_us": { "$ref": "#/$defs/positiveInteger" },
        "topic_change_similarity_threshold": { "type": "number", "minimum": 0, "maximum": 1 },
        "topic_change_visual_window_us": { "$ref": "#/$defs/positiveInteger" },
        "long_pause_warning_us": { "$ref": "#/$defs/positiveInteger" },
        "long_pause_high_us": { "$ref": "#/$defs/positiveInteger" },
        "speech_density_warning_words_per_second": { "type": "number", "exclusiveMinimum": 0, "maximum": 100 },
        "speech_density_high_words_per_second": { "type": "number", "exclusiveMinimum": 0, "maximum": 100 },
        "repetition_similarity_threshold": { "type": "number", "minimum": 0, "maximum": 1 },
        "event_aggregation_gap_us": { "$ref": "#/$defs/positiveInteger" },
        "maximum_content_units": { "$ref": "#/$defs/positiveInteger" },
        "maximum_content_excerpt_characters": { "$ref": "#/$defs/positiveInteger" },
        "maximum_single_excerpt_characters": { "$ref": "#/$defs/positiveInteger" },
        "minimum_excerpt_characters": { "$ref": "#/$defs/positiveInteger" },
        "maximum_semantic_text_characters": { "$ref": "#/$defs/positiveInteger" },
        "excerpt_fraction_limit": { "type": "number", "exclusiveMinimum": 0, "maximum": 1 }
      },
      "additionalProperties": false
    },
    "public_boundary": {
      "type": "object",
      "required": ["absolute_paths_included", "raw_media_included", "raw_audio_included", "raw_frames_included", "full_transcript_included", "raw_process_output_included", "url_query_or_fragment_included", "external_send_enabled", "cloud_asr_enabled", "mcp_execution_enabled"],
      "properties": {
        "absolute_paths_included": { "$ref": "#/$defs/falseFlag" },
        "raw_media_included": { "$ref": "#/$defs/falseFlag" },
        "raw_audio_included": { "$ref": "#/$defs/falseFlag" },
        "raw_frames_included": { "$ref": "#/$defs/falseFlag" },
        "full_transcript_included": { "$ref": "#/$defs/falseFlag" },
        "raw_process_output_included": { "$ref": "#/$defs/falseFlag" },
        "url_query_or_fragment_included": { "$ref": "#/$defs/falseFlag" },
        "external_send_enabled": { "$ref": "#/$defs/falseFlag" },
        "cloud_asr_enabled": { "$ref": "#/$defs/falseFlag" },
        "mcp_execution_enabled": { "$ref": "#/$defs/falseFlag" }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
