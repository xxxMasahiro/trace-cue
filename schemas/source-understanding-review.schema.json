{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://trace-cue.local/schemas/source-understanding-review.schema.json",
  "title": "TraceCue Source Understanding Review",
  "type": "object",
  "required": [
    "schema_version",
    "understanding_version",
    "status",
    "analyst_role",
    "source_text_id",
    "source_type",
    "review_effort",
    "boundary",
    "advisory_only",
    "gate_effect"
  ],
  "properties": {
    "schema_version": { "type": "string" },
    "understanding_version": { "type": ["string", "null"] },
    "status": { "enum": ["completed", "insufficient", "not_supplied"] },
    "analyst_role": { "type": "string" },
    "source_text_id": { "type": ["string", "null"] },
    "source_type": { "enum": ["video", "web_page", "pdf", "meeting_notes", "document", "transcript", "other"] },
    "review_effort": { "enum": ["quick", "standard", "deep", "xhigh", null] },
    "understanding_depth": { "type": ["string", "null"] },
    "topic": { "type": ["string", "null"] },
    "thesis": { "type": ["string", "null"] },
    "audience_promise": { "type": ["string", "null"] },
    "narrative_arc": { "type": "array" },
    "turning_points": { "type": "array" },
    "concrete_examples": { "type": "array" },
    "repeated_motifs": { "type": "array" },
    "must_not_miss_points": { "type": "array" },
    "tensions_or_counterpoints": { "type": "array" },
    "source_limitations": { "type": "array" },
    "reviewer_implications": { "type": "array" },
    "evidence_claims": { "type": "array" },
    "assistant_reference_quality": { "type": "object" },
    "source_excerpt_refs": { "type": "array" },
    "coverage": { "type": "object" },
    "boundary": { "type": "object" },
    "advisory_only": { "const": true },
    "gate_effect": { "const": "none" }
  },
  "additionalProperties": true
}
