{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://trace-cue.local/schemas/agentic-human-review-evidence-regeneration-plan.schema.json",
  "title": "TraceCue Agentic Human Review Evidence Regeneration Plan",
  "type": "object",
  "required": [
    "schema_version",
    "type",
    "regeneration_plan_version",
    "generated_at",
    "status",
    "evidence_set",
    "claim_gate",
    "target_count",
    "provider_execution_approval_required",
    "targets",
    "dependency_plan",
    "downstream_regeneration",
    "execution_boundary",
    "warnings",
    "boundary",
    "advisory_only",
    "gate_effect"
  ],
  "properties": {
    "schema_version": { "type": "string" },
    "type": { "const": "agentic_human_review_evidence_regeneration_plan" },
    "regeneration_plan_version": { "type": "string" },
    "generated_at": { "type": "string" },
    "status": { "enum": ["no_regeneration_required", "regeneration_targets_identified"] },
    "evidence_set": { "type": "object" },
    "claim_gate": { "type": "object" },
    "target_registry": { "type": "object" },
    "target_count": { "type": "number" },
    "provider_execution_approval_required": { "type": "boolean" },
    "targets": { "type": "array" },
    "dependency_plan": { "type": "object" },
    "downstream_regeneration": { "type": "object" },
    "owner_review_context": { "type": "object" },
    "execution_boundary": { "type": "object" },
    "warnings": { "type": "array" },
    "boundary": { "type": "object" },
    "advisory_only": { "const": true },
    "gate_effect": { "const": "none" }
  },
  "additionalProperties": true
}
