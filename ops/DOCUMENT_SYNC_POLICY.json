{
  "schema_version": "1.0.0",
  "kind": "document-sync-policy",
  "excluded_paths": [
    ".browser-debug/**",
    ".trace-cue/**",
    "coverage/**",
    "dist/**",
    "docs/memory/DEVELOPER_MEMORY.md",
    "docs/memory/SESSION_MEMORY.md",
    "node_modules/**",
    "ops/DASHBOARD_SETTINGS.local.json",
    "playwright-report/**",
    "test-results/**"
  ],
  "document_groups": {
    "product_core": {
      "all_of": [
        "docs/product/REQUIREMENTS.md",
        "docs/product/SPECIFICATION.md",
        "docs/product/IMPLEMENTATION_PLAN.md",
        "docs/workflow/TASK_TRACKER.md",
        "docs/workflow/HANDOFF.md"
      ]
    },
    "workflow_pair": {
      "all_of": [
        "docs/workflow/TASK_TRACKER.md",
        "docs/workflow/HANDOFF.md"
      ]
    },
    "verification": {
      "all_of": [
        "docs/workflow/VERIFICATION.md",
        "ops/TEST_PLAN_MANIFEST.tsv"
      ]
    },
    "security": {
      "all_of": [
        "docs/workflow/SECURITY.md",
        "ops/SECURITY_MANIFEST.tsv"
      ]
    },
    "ci_governance": {
      "all_of": [
        "docs/product/IMPLEMENTATION_PLAN.md",
        "docs/workflow/TASK_TRACKER.md",
        "docs/workflow/HANDOFF.md",
        "docs/workflow/VERIFICATION.md",
        "ops/CI_MANIFEST.tsv"
      ]
    },
    "document_sync_governance": {
      "all_of": [
        "docs/workflow/DOCUMENT_SYNC.md",
        "AGENTS.MD",
        "skills/product-doc-sync/SKILL.md",
        "ops/DOCUMENT_SYNC_POLICY.json",
        "schemas/document-sync-policy.schema.json",
        "ops/PRODUCT_MANIFEST.tsv"
      ]
    },
    "development_workflow_governance": {
      "all_of": [
        "docs/workflow/INSTRUCTION_MEMORY.md",
        "AGENTS.MD",
        "skills/product-development-workflow/SKILL.md",
        "ops/DEVELOPMENT_WORKFLOW_POLICY.json",
        "schemas/development-workflow-policy.schema.json",
        "ops/PRODUCT_MANIFEST.tsv",
        "ops/TEST_PLAN_MANIFEST.tsv"
      ]
    },
    "verification_governance": {
      "all_of": [
        "docs/workflow/VERIFICATION.md",
        "docs/workflow/SECURITY.md",
        "ops/VERIFICATION_EXECUTION_POLICY.json",
        "schemas/verification-execution-policy.schema.json",
        "ops/TEST_PLAN_MANIFEST.tsv",
        "ops/CI_MANIFEST.tsv",
        "ops/SECURITY_MANIFEST.tsv"
      ]
    }
  },
  "rules": [
    {
      "id": "canonical-product-documents",
      "description": "Keep the five product and workflow authorities synchronized when a canonical product document changes.",
      "trigger": {
        "any_of": [
          "docs/product/REQUIREMENTS.md",
          "docs/product/SPECIFICATION.md",
          "docs/product/IMPLEMENTATION_PLAN.md"
        ]
      },
      "required_groups": ["product_core"]
    },
    {
      "id": "workflow-state-pair",
      "description": "Task tracker and handoff are one workflow-state pair.",
      "trigger": {
        "any_of": [
          "docs/workflow/TASK_TRACKER.md",
          "docs/workflow/HANDOFF.md"
        ]
      },
      "required_groups": ["workflow_pair"]
    },
    {
      "id": "document-sync-authority",
      "description": "Changes to document-sync enforcement must update its complete governance contract.",
      "trigger": {
        "any_of": [
          ".githooks/pre-push",
          "AGENTS.MD",
          "docs/workflow/DOCUMENT_SYNC.md",
          "ops/DOCUMENT_SYNC_POLICY.json",
          "schemas/document-sync-policy.schema.json",
          "skills/product-doc-sync/SKILL.md",
          "tools/check_document_sync.mjs",
          "tests/document-sync.test.js",
          "tools/install-git-hooks",
          "tools/lib/document-sync.mjs"
        ]
      },
      "required_groups": ["product_core", "verification", "security", "document_sync_governance"],
      "cannot_be_exempted": true
    },
    {
      "id": "development-workflow-authority",
      "description": "Durable development instructions and their machine enforcement must update the complete workflow governance and product safety contract.",
      "trigger": {
        "any_of": [
          "docs/workflow/INSTRUCTION_MEMORY.md",
          "ops/DEVELOPMENT_WORKFLOW_POLICY.json",
          "schemas/development-workflow-policy.schema.json",
          "tools/check_development_workflow.mjs",
          "tools/lib/development-workflow.mjs",
          "tests/development-workflow.test.js"
        ]
      },
      "required_groups": ["product_core", "verification", "security", "development_workflow_governance"],
      "cannot_be_exempted": true
    },
    {
      "id": "ci-governance",
      "description": "CI contract changes must update verification, workflow state, and the CI manifest.",
      "trigger": {
        "any_of": [
          ".github/workflows/**",
          "ops/CI_MANIFEST.tsv",
          "tools/check_product_ci.sh"
        ]
      },
      "required_groups": ["ci_governance"]
    },
    {
      "id": "verification-orchestration-authority",
      "description": "Verification ownership, execution, evidence, cache, package, and CI proof changes must update the complete product, workflow, verification, and security contract.",
      "trigger": {
        "any_of": [
          "ops/VERIFICATION_EXECUTION_POLICY.json",
          "schemas/verification-execution-policy.schema.json",
          "tools/verification.mjs",
          "tools/check_verification_ci.mjs",
          "tools/check_ci_status.sh",
          "tools/lib/verification-*.mjs",
          "tools/lib/product-gate-evidence.mjs",
          "tools/lib/product_gate_evidence.sh",
          "tools/lib/package-artifact.mjs",
          "tools/pack-*.mjs",
          "tests/verification-*.test.js",
          "tests/package-artifact.test.js"
        ]
      },
      "required_groups": ["product_core", "verification", "security", "ci_governance", "verification_governance"],
      "cannot_be_exempted": true
    },
    {
      "id": "dashboard-settings-persistence",
      "description": "Changes to shared defaults or local settings persistence require product, verification, and security synchronization.",
      "trigger": {
        "any_of": [
          "ops/DASHBOARD_SETTINGS.json",
          "src/dashboard-settings-store.js",
          "src/control-center-settings.js",
          "src/control-center-preferences.js",
          "src/control-center-actions.js",
          "src/playwright-test-integration.js"
        ]
      },
      "required_groups": ["product_core", "verification", "security"],
      "cannot_be_exempted": true
    },
    {
      "id": "agentic-human-review-and-provider-boundaries",
      "description": "Agentic review and provider changes require product, verification, and security synchronization.",
      "trigger": {
        "any_of": [
          "bin/trace-cue-ahr-responses-adapter.js",
          "schemas/agentic-human-review-*.schema.json",
          "schemas/control-center-ai-connections.schema.json",
          "src/agent-execution*.js",
          "src/agentic-human-review*.js",
          "src/codex-subscription*.js",
          "src/control-center-agentic-review-actions.js",
          "src/control-center-ai-*.js",
          "src/fixed-process-runner.js",
          "src/json-schema-subset.js"
        ]
      },
      "required_groups": ["product_core", "verification", "security"],
      "cannot_be_exempted": true
    },
    {
      "id": "mcp-authority",
      "description": "MCP transport, profile, capability, and execution changes require full safety synchronization.",
      "trigger": {
        "any_of": [
          ".mcp.json",
          "bin/*-mcp.js",
          "schemas/mcp-*.schema.json",
          "src/mcp*.js"
        ]
      },
      "required_groups": ["product_core", "verification", "security"],
      "cannot_be_exempted": true
    },
    {
      "id": "persistent-browser-session",
      "description": "Persistent browser session changes require full safety synchronization.",
      "trigger": {
        "any_of": [
          "schemas/persistent-session.schema.json",
          "schemas/session-action.schema.json",
          "src/browser-session-*.js",
          "src/sessions.js",
          "src/supervisor.js"
        ]
      },
      "required_groups": ["product_core", "verification", "security"],
      "cannot_be_exempted": true
    },
    {
      "id": "evidence-evaluation-and-claim-boundaries",
      "description": "Evidence, evaluation, and claim logic changes require full product and safety synchronization.",
      "trigger": {
        "any_of": [
          "schemas/*evidence*.schema.json",
          "schemas/*evaluation*.schema.json",
          "schemas/*claim*.schema.json",
          "schemas/finding.schema.json",
          "schemas/human-review-rubric.schema.json",
          "schemas/review.schema.json",
          "src/page-evidence.js",
          "src/review.js",
          "src/visual-evidence.js",
          "src/visual-review-*.js"
        ]
      },
      "required_groups": ["product_core", "verification", "security"],
      "cannot_be_exempted": true
    }
  ]
}
