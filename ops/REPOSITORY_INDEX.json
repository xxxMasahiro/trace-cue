{
  "schema_version": "1.0.0",
  "root_name": "browser-debug-cli",
  "source": "external_product_repository",
  "default_expand_depth": 1,
  "excludes": [
    { "pattern": "node_modules/", "reason": "dependency cache" },
    { "pattern": ".browser-debug/", "reason": "local debug artifacts" },
    { "pattern": ".env*", "reason": "secret-bearing configuration" }
  ],
  "roles": {
    "agent_entry": {
      "label": "Agent entry",
      "description": "Repository-local operating rules"
    },
    "product_doc": {
      "label": "Product document",
      "description": "Canonical planning and behavior document"
    },
    "workflow_doc": {
      "label": "Workflow document",
      "description": "Task state, handoff, security, or verification document"
    },
    "manifest": {
      "label": "Manifest",
      "description": "Machine-readable product authority file"
    },
    "ci_config": {
      "label": "CI config",
      "description": "Local CI configuration and manifest"
    }
  },
  "files": [
    { "path": "AGENTS.MD", "role": "agent_entry" },
    { "path": "CHANGELOG.md", "role": "workflow_doc" },
    { "path": ".github/workflows/ci.yml", "role": "ci_config" },
    { "path": "package.json", "role": "manifest" },
    { "path": "package-lock.json", "role": "manifest" },
    { "path": "bin/browser-debug.js", "role": "manifest" },
    { "path": "src/cli.js", "role": "manifest" },
    { "path": "src/daemon.js", "role": "manifest" },
    { "path": "src/daemon-worker.js", "role": "manifest" },
    { "path": "src/page-evidence.js", "role": "manifest" },
    { "path": "src/observe.js", "role": "manifest" },
    { "path": "src/sessions.js", "role": "manifest" },
    { "path": "src/supervisor.js", "role": "manifest" },
    { "path": "tests/architecture.test.js", "role": "manifest" },
    { "path": "tests/cli.test.js", "role": "manifest" },
    { "path": "tests/browser-smoke.test.js", "role": "manifest" },
    { "path": "docs/product/REQUIREMENTS.md", "role": "product_doc" },
    { "path": "docs/product/SPECIFICATION.md", "role": "product_doc" },
    { "path": "docs/product/IMPLEMENTATION_PLAN.md", "role": "product_doc" },
    { "path": "docs/workflow/TASK_TRACKER.md", "role": "workflow_doc" },
    { "path": "docs/workflow/HANDOFF.md", "role": "workflow_doc" },
    { "path": "docs/workflow/RELEASE.md", "role": "workflow_doc" },
    { "path": "ops/CI_MANIFEST.tsv", "role": "ci_config" },
    { "path": "ops/PRODUCT_MANIFEST.tsv", "role": "manifest" }
  ]
}
