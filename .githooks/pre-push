#!/usr/bin/env bash
set -euo pipefail

ROOT="$(git rev-parse --show-toplevel)"
REMOTE_NAME="${1:-origin}"
ZERO_SHA="0000000000000000000000000000000000000000"
checked=0

node "$ROOT/tools/verification.mjs" check

while read -r local_ref local_sha remote_ref remote_sha; do
  [[ -n "${local_ref:-}" ]] || continue
  [[ "$local_sha" != "$ZERO_SHA" ]] || continue
  [[ "$local_ref" == refs/heads/* ]] || continue

  if [[ "$remote_sha" == "$ZERO_SHA" ]]; then
    remote_head="$(git symbolic-ref --quiet "refs/remotes/$REMOTE_NAME/HEAD" 2>/dev/null || true)"
    if [[ -z "$remote_head" ]]; then
      printf 'Document sync pre-push check cannot resolve %s/HEAD. Fetch the remote default branch first.\n' "$REMOTE_NAME" >&2
      exit 1
    fi
    base_sha="$(git merge-base "$local_sha" "$remote_head")"
  else
    base_sha="$remote_sha"
  fi

  node "$ROOT/tools/check_document_sync.mjs" --repo "$ROOT" --base "$base_sha" --head "$local_sha"
  node "$ROOT/tools/verification.mjs" plan --profile focused --base "$base_sha" --head "$local_sha" >/dev/null
  checked=$((checked + 1))
done

if [[ "$checked" -eq 0 ]]; then
  printf 'Document sync pre-push check: no branch updates to inspect.\n'
fi
